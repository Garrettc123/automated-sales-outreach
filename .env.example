# OpenAI
OPENAI_API_KEY=sk-your-key

# Server
PORT=8000
ALLOWED_ORIGINS=*

# Email delivery (at least one required for actual sending)
SENDGRID_API_KEY=SG.your-key
POSTMARK_SERVER_TOKEN=your-postmark-token
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=outreach@yourdomain.com
FROM_NAME=Your Name

# Unsubscribe footer
UNSUBSCRIBE_BASE_URL=https://your-app.railway.app

# Lead sourcing (optional – used for prospect enrichment)
APOLLO_API_KEY=your-apollo-key
HUNTER_API_KEY=your-hunter-key

# Stripe billing
STRIPE_SECRET_KEY=sk_live_or_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
STRIPE_STARTER_PRICE_ID=price_xxxx
STRIPE_PRO_PRICE_ID=price_yyyy
STRIPE_AGENCY_PRICE_ID=price_zzzz

# Calendly
CALENDLY_URL=https://calendly.com/your-link

# Database (defaults to SQLite; set for PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

